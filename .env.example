# Optional. Defaults to 8080.
PORT=8080

# Optional. When set, /api/* and /ws/* require this token.
AUTH_TOKEN=

# Required for audio transcription uploads.
OPENAI_API_KEY=

# Optional. Defaults to gpt-4o-mini-transcribe.
TCLAW_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Required by ./deploy-local.sh when deploying from a source checkout on a server.
TCLAW_RUNTIME_DIR=/home/ploi/tclaw

# Optional deploy-local.sh settings.
TCLAW_SERVICE=tclaw
TCLAW_BUILD_OUTPUT=tclaw-linux-amd64
